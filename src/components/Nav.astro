---
const navLinks = [
  { href: '/features', label: 'Features' },
  { href: '/pricing', label: 'Pricing' },
  { href: '/faq', label: 'FAQ' },
  { href: '/blog', label: 'Blog' },
  { href: 'https://docs.crontinel.com', label: 'Docs', external: true },
];
---

<header class="sticky top-0 z-40 border-b border-gray-800/60 bg-gray-950/90 backdrop-blur">
  <nav class="max-w-5xl mx-auto px-4 sm:px-6 flex items-center justify-between h-14">
    <a href="/" class="flex items-center gap-2 font-semibold text-white">
      <img src="/logo-light.png" alt="Crontinel" width="22" height="22" class="shrink-0" />
      <span>Crontinel</span>
    </a>

    <div class="hidden md:flex items-center gap-6">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="text-sm text-gray-400 hover:text-white transition-colors"
          {...(link.external ? { target: '_blank', rel: 'noopener' } : {})}
        >
          {link.label}
        </a>
      ))}
    </div>

    <div class="flex items-center gap-3">
      <a href="/#waitlist" class="text-sm bg-green-500 hover:bg-green-400 text-black font-medium px-4 py-1.5 rounded transition-colors">
        Get early access
      </a>
    </div>
  </nav>
</header>
